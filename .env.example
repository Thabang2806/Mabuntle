ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=swyftly;Username=swyftly;Password=change_me

POSTGRES_DB=swyftly
POSTGRES_USER=swyftly
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

SWYFTLY_WEB_API_BASE_URL=https://localhost:7268

Jwt__Issuer=Swyftly.Api
Jwt__Audience=Swyftly.Web
Jwt__SigningKey=change_me_minimum_32_characters_for_local_development
Jwt__AccessTokenMinutes=30
Jwt__RefreshTokenDays=14

AuthCookies__RefreshTokenPath=/api/auth
AuthCookies__CsrfPath=/
AuthCookies__Domain=
AuthCookies__SameSite=Lax
AuthCookies__Secure=true

PaymentProvider__ProviderName=Fake
PaymentProvider__DefaultCurrency=ZAR
PaymentProvider__SuccessRedirectUrl=http://localhost:4200/checkout/success
PaymentProvider__FailureRedirectUrl=http://localhost:4200/checkout/failed
PaymentProvider__WebhookSigningSecret=
PaymentProvider__FakeOutcome=Success

PaymentWebhookPayloadRetention__Enabled=true
PaymentWebhookPayloadRetention__RetentionDays=90
PaymentWebhookPayloadRetention__BatchSize=500

# Provider placeholders. Leave credential values empty unless configuring a real provider locally.
# Supported values for PaymentProvider__ProviderName: Fake, PayFast. PayU is documented but not implemented.
PayFast__MerchantId=
PayFast__MerchantKey=
PayFast__Passphrase=
PayFast__ProcessUrl=
PayFast__ValidateUrl=
PayFast__NotifyUrl=
PayFast__CheckoutBridgeBaseUrl=
PayFast__RequireRemoteValidation=true

PayU__Region=SouthAfrica
PayU__Username=
PayU__Password=
PayU__Safekey=
PayU__PaymentPageUrl=
PayU__WebhookSigningKey=

PayoutProvider__ProviderName=Fake
PayoutProvider__FakeOutcome=PaidOut

Ledger__PlatformCommissionRatePercent=10
Ledger__PaymentProviderFeeRatePercent=2.5
Ledger__PaymentProviderFixedFee=0

SwyftlyRateLimits__Auth__PermitLimit=30
SwyftlyRateLimits__Auth__WindowSeconds=60
SwyftlyRateLimits__Webhook__PermitLimit=120
SwyftlyRateLimits__Webhook__WindowSeconds=60
SwyftlyRateLimits__AdImpression__PermitLimit=300
SwyftlyRateLimits__AdImpression__WindowSeconds=60

SWYFTLY_RUN_POSTGRES_TESTS=false
SWYFTLY_TEST_POSTGRES_CONNECTION=Host=localhost;Port=5432;Database=swyftly_integration_tests;Username=swyftly;Password=change_me
